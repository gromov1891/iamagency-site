# Public application settings (available during the Next.js build)
NEXT_PUBLIC_SITE_URL=https://iamagency.su
NEXT_PUBLIC_YANDEX_METRIKA_ID=99802137
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Timeweb S3 (public bucket for CMS media)
S3_ENDPOINT=https://s3.twcstorage.ru
S3_REGION=ru-1
S3_BUCKET=iamagency-cms
S3_ACCESS_KEY_ID=replace-me
S3_SECRET_ACCESS_KEY=replace-me
S3_PUBLIC_URL=https://iamagency-cms.s3.twcstorage.ru
S3_FORCE_PATH_STYLE=false

# CMS administrator
CMS_ADMIN_USER=replace-me
CMS_ADMIN_PASSWORD=replace-me
CMS_SESSION_SECRET=replace-with-a-long-random-string

# Lead delivery by email
LEADS_EMAIL_TO=replace-me@example.com
LEADS_SMTP_HOST=smtp.example.com
LEADS_SMTP_PORT=465
LEADS_SMTP_USER=replace-me@example.com
LEADS_SMTP_PASSWORD=replace-me
# LEADS_SMTP_FROM=I AM AGENCY <replace-me@example.com>

# Lead delivery to the marketing Telegram chat
LEADS_TELEGRAM_BOT_TOKEN=replace-me
LEADS_TELEGRAM_CHAT_ID=replace-me

# HTTPS delivery relay for hosts that block outbound SMTP/Telegram traffic
LEADS_DELIVERY_WEBHOOK_URL=https://example.com/webhook/iamagency-leads
LEADS_DELIVERY_WEBHOOK_SECRET=replace-with-a-long-random-string
